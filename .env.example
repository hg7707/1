# Server
PORT=3000
NODE_ENV=production

# Public site AI provider. Put your SiliconFlow API key here on the server.
SILICONFLOW_API_KEY=your_siliconflow_api_key
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3.2
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# Optional OpenAI fallback. Usually leave empty if you use SiliconFlow.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Public safety controls
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX=80
TRUST_PROXY=true

# Keep false for public websites. If true, users can submit their own API keys from the browser.
ALLOW_CLIENT_API_KEYS=false
